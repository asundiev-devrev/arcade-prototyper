# Registry mapping for the private @xorkavi scope (non-secret — safe to commit).
# Fresh clones need this to locate @xorkavi/arcade-gen.
@xorkavi:registry=https://npm.pkg.github.com

# The auth token does NOT go here. pnpm 10 refuses to expand env vars in a project
# .npmrc (it could leak to an attacker-controlled registry). Put it in your USER-level
# ~/.npmrc instead, where pnpm trusts env expansion:
#   //npm.pkg.github.com/:_authToken=${GITHUB_TOKEN_PACKAGES}
# then export GITHUB_TOKEN_PACKAGES=<a GitHub token with the read:packages scope>.
