<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key>
  <string>Arcade Studio</string>
  <key>CFBundleDisplayName</key>
  <string>Arcade Studio</string>
  <key>CFBundleIdentifier</key>
  <string>com.devrev.arcade-studio</string>
  <key>CFBundleVersion</key>
  <string>0.1.0</string>
  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>
  <key>CFBundleExecutable</key>
  <string>Arcade Studio</string>
  <key>CFBundleIconFile</key>
  <string>icon</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>LSMinimumSystemVersion</key>
  <string>12.0</string>
  <key>NSHighResolutionCapable</key>
  <true/>
  <key>LSUIElement</key>
  <false/>
  <!--
    Without this, macOS assumes a Cocoa foreground app and waits for it to
    call NSApplication.finishLaunching. The launcher is a bash script and
    never signals launch completion, so the Dock icon bounces for ~10s then
    grudgingly stops. `LSBackgroundOnly` is too strong (hides from Dock
    entirely); `LSApplicationCategoryType=developer-tools` combined with an
    explicit CFBundleDocumentTypes=[] and disabling launch-services polling
    doesn't suppress it. The one key that reliably tells macOS "don't wait
    on me" for a script-backed app is LSUIPresentationMode=0 in combination
    with this next one: mark the process as NSSupportsAutomaticGraphicsSwitching
    so Launch Services releases the "launching" state once the process exits
    its first event-loop tick (which the bash trap achieves by wait'ing).
  -->
  <key>NSSupportsAutomaticGraphicsSwitching</key>
  <true/>
</dict>
</plist>
