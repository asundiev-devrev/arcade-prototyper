{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["main.ts", "viteRunner.ts", "updater.ts", "applyDecision.ts", "telemetry.ts", "shared/awsBootstrap.ts"],
  "exclude": ["dist"]
}
